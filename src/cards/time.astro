---
import { Card } from "studiocms:ui/components/card";

import { useTastro } from "@sipc.ink/tastro"
const { t } = useTastro(Astro.request)
---

<Card class="glass-card" style="width: 100%; height: 100%;">
    <h4 slot="header">⏰ {t("time.title")}</h4>
    <div id="time-display" style="font-size: 2em; font-weight: bold; text-align: center;">
        Loading...
    </div>
    <script>
        function updateTime() {
            const now = new Date();
            const options = { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
            document.getElementById('time-display').textContent = now.toLocaleTimeString('zh-CN', options);
        }
        updateTime();
        setInterval(updateTime, 1000);
    </script>
</Card>
