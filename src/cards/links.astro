---
import { Button } from "studiocms:ui/components/button";
import Github from "../assets/icon/github.svg";
import Bilibili from "../assets/icon/bilibili.svg";

import { useTastro } from "@sipc.ink/tastro"
const { t } = useTastro(Astro.request)
---

<div class="glass-card" style="width: 100%; height: 100%; padding: 20px; background: rgba(20, 20, 20, 0.65); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.08);">
    <h4 style="margin-bottom: 12px; font-size: 16px;">🔗 {t("links.title")}</h4>
    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
        <Button color="default" variant="outlined" target="_blank" as="a" href="https://github.com/th-dd" style="padding: 12px; border-radius: 12px;">
            <Github />
        </Button>
        <Button color="default" variant="outlined" target="_blank" as="a" href="https://space.bilibili.com/1564506743" style="padding: 12px; border-radius: 12px;">
            <Bilibili />
        </Button>
        <Button color="default" variant="outlined" target="_blank" as="a" href="https://qm.qq.com/q/jvHsCgdhg4" style="padding: 12px; border-radius: 12px; font-size: 12px;">
            QQ
        </Button>
        <Button color="default" variant="outlined" target="_blank" as="a" href="https://docs.th-dd.top" style="padding: 12px; border-radius: 12px; font-size: 12px;">
            📚 Docs
        </Button>
        <Button color="default" variant="outlined" target="_blank" as="a" href="https://sys.th-dd.top" style="padding: 12px; border-radius: 12px; font-size: 12px;">
            📊 Status
        </Button>
    </div>
</div>
