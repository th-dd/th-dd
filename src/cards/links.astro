---
import { useTastro } from "@sipc.ink/tastro"
const { t } = useTastro(Astro.request)

import Github from "../assets/icon/github.svg";
import Bilibili from "../assets/icon/bilibili.svg";
import QQ from "../assets/icon/qq.svg";
---

<div class="glass-card" style="width: 100%; height: 100%; padding: 20px;">
    <h4 style="margin-bottom: 12px; font-size: 16px;">🔗 {t("links.title")}</h4>
    <div class="links-container">
        <a href="https://github.com/th-dd" target="_blank" class="link-btn">
            <Github />
        </a>
        <a href="https://space.bilibili.com/1217732687" target="_blank" class="link-btn">
            <Bilibili />
        </a>
        <a href="https://qm.qq.com/q/jvHsCgdhg4" target="_blank" class="link-btn">
            <QQ />
        </a>
        <a href="https://docs.th-dd.top" target="_blank" class="link-btn text-btn">📚 Docs</a>
        <a href="https://sys.th-dd.top" target="_blank" class="link-btn text-btn">📊 Status</a>
    </div>
</div>

<style>
    .links-container {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }
    
    .link-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: rgba(128, 128, 128, 0.15);
        color: var(--text-primary);
        border: 1px solid var(--border-color);
        text-decoration: none;
        transition: all 0.3s ease;
    }
    
    .link-btn:hover {
        background: rgba(128, 128, 128, 0.3);
        transform: translateY(-2px);
    }
    
    .link-btn.text-btn {
        width: auto;
        padding: 0 16px;
        font-size: 13px;
    }
    
    .link-btn svg {
        width: 20px;
        height: 20px;
        fill: var(--btn-text);
    }
</style>
