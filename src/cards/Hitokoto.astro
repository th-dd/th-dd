---
// 一言组件 - 使用 hitokoto API
---

<div class="glass-card hitokoto-card">
    <div class="hitokoto-content">
        <span class="hitokoto-text" id="hitokoto-text">加载中...</span>
        <span class="hitokoto-from" id="hitokoto-from"></span>
    </div>
    <button class="refresh-btn" id="refresh-btn" title="换一条">
        🔄
    </button>
</div>

<style>
    .hitokoto-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 20px;
        width: 100%;
    }
    
    .hitokoto-content {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
        min-width: 0;
    }
    
    .hitokoto-text {
        font-size: 14px;
        line-height: 1.5;
        color: var(--text-primary);
        word-break: break-word;
    }
    
    .hitokoto-from {
        font-size: 12px;
        color: var(--text-muted);
        text-align: right;
    }
    
    .refresh-btn {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid var(--border-color);
        background: var(--btn-bg);
        color: var(--text-primary);
        cursor: pointer;
        font-size: 16px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .refresh-btn:hover {
        background: var(--btn-bg);
        transform: rotate(180deg);
    }
    
    .refresh-btn.loading {
        animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>

<script>
    const textEl = document.getElementById('hitokoto-text');
    const fromEl = document.getElementById('hitokoto-from');
    const refreshBtn = document.getElementById('refresh-btn');
    
    async function fetchHitokoto() {
        refreshBtn.classList.add('loading');
        textEl.textContent = '加载中...';
        fromEl.textContent = '';
        
        try {
            const response = await fetch('https://v1.hitokoto.cn');
            const data = await response.json();
            
            textEl.textContent = data.hitokoto || '获取失败';
            
            if (data.from) {
                fromEl.textContent = `—— ${data.from}`;
            }
        } catch (error) {
            textEl.textContent = '获取一言失败，请重试';
            console.error('Hitokoto API error:', error);
        } finally {
            refreshBtn.classList.remove('loading');
        }
    }
    
    // 初始加载
    fetchHitokoto();
    
    // 点击刷新
    refreshBtn.addEventListener('click', fetchHitokoto);
</script>
