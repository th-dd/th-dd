---
// 一言组件 - 使用 hitokoto API
---

<div class="glass-card hitokoto-card">
    <div class="hitokoto-content">
        <span class="hitokoto-text" id="hitokoto-text">加载中...</span>
        <span class="hitokoto-from" id="hitokoto-from"></span>
    </div>
    <div class="hitokoto-actions">
        <button class="action-btn" id="copy-btn" title="复制一言">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
        </button>
        <button class="action-btn" id="refresh-btn" title="换一条">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 4v6h-6"></path>
                <path d="M1 20v-6h6"></path>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            </svg>
        </button>
    </div>
</div>

<style>
    .hitokoto-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 20px;
        width: 100%;
    }
    
    .hitokoto-content {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
        min-width: 0;
    }
    
    .hitokoto-text {
        font-size: 14px;
        line-height: 1.5;
        color: var(--text-primary);
        word-break: break-word;
    }
    
    .hitokoto-from {
        font-size: 12px;
        color: var(--text-muted);
        text-align: right;
    }
    
    .hitokoto-actions {
        display: flex;
        gap: 8px;
        flex-shrink: 0;
    }
    
    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        background: var(--btn-bg);
        color: var(--text-primary);
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .action-btn:hover {
        background: rgba(128, 128, 128, 0.25);
        transform: translateY(-2px);
    }
    
    .action-btn.copied {
        background: rgba(76, 175, 80, 0.3);
        border-color: #4CAF50;
    }
    
    .action-btn.loading svg {
        animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>

<script>
    const textEl = document.getElementById('hitokoto-text');
    const fromEl = document.getElementById('hitokoto-from');
    const refreshBtn = document.getElementById('refresh-btn');
    const copyBtn = document.getElementById('copy-btn');
    
    let currentText = '';
    
    async function fetchHitokoto() {
        refreshBtn.classList.add('loading');
        textEl.textContent = '加载中...';
        fromEl.textContent = '';
        
        try {
            const response = await fetch('https://v1.hitokoto.cn');
            const data = await response.json();
            
            currentText = data.hitokoto || '获取失败';
            textEl.textContent = currentText;
            
            if (data.from) {
                fromEl.textContent = `—— ${data.from}`;
            }
        } catch (error) {
            textEl.textContent = '获取一言失败，请重试';
            currentText = '';
            console.error('Hitokoto API error:', error);
        } finally {
            refreshBtn.classList.remove('loading');
        }
    }
    
    async function copyHitokoto() {
        if (!currentText) return;
        
        try {
            await navigator.clipboard.writeText(currentText);
            
            // 显示复制成功状态
            copyBtn.classList.add('copied');
            copyBtn.innerHTML = `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
            
            setTimeout(() => {
                copyBtn.classList.remove('copied');
                copyBtn.innerHTML = `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
            }, 1500);
        } catch (error) {
            console.error('Copy failed:', error);
        }
    }
    
    // 初始加载
    fetchHitokoto();
    
    // 点击刷新
    refreshBtn.addEventListener('click', fetchHitokoto);
    
    // 点击复制
    copyBtn.addEventListener('click', copyHitokoto);
</script>
