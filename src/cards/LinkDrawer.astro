---
// 链接预览抽屉组件
const links = [
    { name: "GitHub", url: "https://github.com/th-dd" },
    { name: "Bilibili", url: "https://space.bilibili.com/1217732687" },
    { name: "文档站", url: "https://docs.th-dd.top" },
    { name: "服务器监控", url: "https://sys.th-dd.top" }
]
---

<div id="link-drawer" class="link-drawer">
    <!-- 抽屉切换按钮 -->
    <button id="drawer-toggle" class="drawer-toggle" aria-label="展开链接预览">
        <span class="toggle-icon">🔗</span>
        <span class="toggle-arrow">▲</span>
    </button>
    
    <!-- 抽屉内容 -->
    <div class="drawer-content">
        <!-- 链接标签栏 -->
        <div class="link-tabs">
            {links.map((link, index) => (
                <button 
                    class={`link-tab ${index === 0 ? 'active' : ''}`}
                    data-url={link.url}
                    data-index={index}
                >
                    {link.name}
                </button>
            ))}
        </div>
        
        <!-- 预览区域 -->
        <div class="preview-container">
            <iframe id="preview-frame" src="" class="preview-frame"></iframe>
            <div class="preview-placeholder">
                <span>点击上方标签预览链接内容</span>
            </div>
        </div>
        
        <!-- 控制栏 -->
        <div class="drawer-controls">
            <button id="open-link-btn" class="control-btn" title="在新窗口打开">
                🔗 在新窗口打开
            </button>
        </div>
    </div>
</div>

<style>
    .link-drawer {
        position: fixed;
        z-index: 99;
        bottom: 20px;
        right: 20px;
    }
    
    .drawer-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        border-radius: 25px;
        border: none;
        cursor: pointer;
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        font-size: 14px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }
    
    .drawer-toggle:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    }
    
    .toggle-arrow {
        transition: transform 0.3s ease;
    }
    
    .link-drawer.open .toggle-arrow {
        transform: rotate(180deg);
    }
    
    .drawer-content {
        position: absolute;
        bottom: 60px;
        right: 0;
        width: 400px;
        max-height: 0;
        overflow: hidden;
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 16px;
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
        opacity: 0;
    }
    
    .link-drawer.open .drawer-content {
        max-height: 500px;
        opacity: 1;
    }
    
    .link-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 12px;
        border-bottom: 1px solid var(--border-color);
    }
    
    .link-tab {
        padding: 8px 16px;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        background: transparent;
        color: var(--text-primary);
        cursor: pointer;
        font-size: 13px;
        transition: all 0.3s ease;
    }
    
    .link-tab:hover {
        background: var(--btn-bg);
    }
    
    .link-tab.active {
        background: var(--btn-bg);
        border-color: var(--text-primary);
    }
    
    .preview-container {
        position: relative;
        height: 300px;
        background: var(--bg-card-inner);
    }
    
    .preview-frame {
        width: 100%;
        height: 100%;
        border: none;
        display: none;
    }
    
    .preview-frame.active {
        display: block;
    }
    
    .preview-placeholder {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: var(--text-muted);
        font-size: 14px;
        text-align: center;
    }
    
    .preview-placeholder.hidden {
        display: none;
    }
    
    .drawer-controls {
        display: flex;
        gap: 8px;
        padding: 12px;
        border-top: 1px solid var(--border-color);
    }
    
    .control-btn {
        flex: 1;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        background: transparent;
        color: var(--text-primary);
        cursor: pointer;
        font-size: 13px;
        transition: all 0.3s ease;
    }
    
    .control-btn:hover {
        background: var(--btn-bg);
    }
    
    /* 手机端样式 */
    @media (max-width: 768px) {
        .link-drawer {
            left: 20px;
            right: 20px;
            bottom: 20px;
        }
        
        .drawer-toggle {
            width: 100%;
            justify-content: center;
        }
        
        .drawer-content {
            position: fixed;
            left: 20px;
            right: 20px;
            bottom: 80px;
            width: auto;
        }
        
        .preview-container {
            height: 250px;
        }
    }
</style>

<script>
    const drawer = document.getElementById('link-drawer');
    const toggle = document.getElementById('drawer-toggle');
    const tabs = document.querySelectorAll('.link-tab');
    const frame = document.getElementById('preview-frame');
    const placeholder = document.querySelector('.preview-placeholder');
    const openLinkBtn = document.getElementById('open-link-btn');
    
    let currentUrl = '';
    
    // 切换抽屉
    toggle.addEventListener('click', () => {
        drawer.classList.toggle('open');
    });
    
    // 点击标签切换链接
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const url = tab.dataset.url;
            
            // 更新激活状态
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            
            // 加载预览
            currentUrl = url;
            frame.src = url;
            frame.classList.add('active');
            placeholder.classList.add('hidden');
        });
    });
    
    // 在新窗口打开链接
    openLinkBtn.addEventListener('click', () => {
        if (currentUrl) {
            window.open(currentUrl, '_blank');
        }
    });
</script>
