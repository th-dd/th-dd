---
import { useTastro } from "@sipc.ink/tastro"
const { t } = useTastro(Astro.request)
---

<div class="glass-card" style="width: 100%; height: 100%; padding: 20px;">
    <h4 style="margin-bottom: 12px; font-size: 16px;">🛠️ {t("projects.title")}</h4>
    <div style="display: flex; flex-direction: column; gap: 12px;">
        <div class="inner-card" style="padding: 12px; border-radius: 12px;">
            <h5 style="margin-bottom: 4px;">
                <a href="https://docs.th-dd.top/thbot-commads.html" style="text-decoration: none;">{t("projects.project1.name")}</a>
            </h5>
            <p style="font-size: 13px; margin: 0; line-height: 1.4;">
                {t("projects.project1.desc")}
            </p>
        </div>
        <div class="inner-card" style="padding: 12px; border-radius: 12px;">
            <h5 style="margin-bottom: 4px;">
                <a href="https://docs.th-dd.top/nobot-commads.html" style="text-decoration: none;">{t("projects.project2.name")}</a>
            </h5>
            <p style="font-size: 13px; margin: 0; line-height: 1.4;">
                {t("projects.project2.desc")}
            </p>
        </div>
        <div class="inner-card" style="padding: 12px; border-radius: 12px;">
            <h5 style="margin-bottom: 4px;">
                <a href="https://docs.th-dd.top" style="text-decoration: none;">{t("projects.project3.name")}</a>
            </h5>
            <p style="font-size: 13px; margin: 0; line-height: 1.4;">
                {t("projects.project3.desc")}
            </p>
        </div>
    </div>
</div>
