---
import { useTastro } from "@sipc.ink/tastro"
const { t } = useTastro(Astro.request)
---

<div class="glass-card" style="width: 100%; height: 100%; padding: 20px;">
    <h4 style="margin-bottom: 12px; font-size: 16px;">🧑‍💻 {t("about.title")}</h4>
    <div style="display: flex; flex-direction: column; gap: 8px;">
        <del style="color: var(--text-muted);">{t("about.old")}</del>
        <div style="color: var(--text-secondary);">{t("about.content")}</div>
    </div>
</div>
