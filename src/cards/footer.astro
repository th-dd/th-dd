---
import { useTastro } from "@sipc.ink/tastro"
const { t } = useTastro(Astro.request)
---

<div class="glass-card" style="width: 100%; padding: 16px 20px;">
    <div class="footer-content">
        <div class="footer-top">
            <span>© {new Date().getFullYear()}</span>
            <a href="https://th-dd.top" style="color: inherit; text-decoration: none;">
                {t("footer.site")}
            </a>
            <a href="https://hyperos.mi.com/font" style="color: inherit; text-decoration: none;">
                {t("footer.font")}
            </a>
        </div>
        <div class="footer-bottom">
            <a href="https://icp.gov.moe/?keyword=20261666" target="_blank" style="color: inherit; text-decoration: none;">
                萌ICP备20261666号
            </a>
        </div>
    </div>
</div>

<style>
    .footer-content {
        display: flex;
        flex-direction: column;
        gap: 8px;
        color: var(--text-muted);
    }
    
    .footer-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    
    .footer-bottom {
        text-align: center;
        font-size: 12px;
    }
</style>
