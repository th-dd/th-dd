---
import { useTastro } from "@sipc.ink/tastro"
const { t } = useTastro(Astro.request)
---

<div class="glass-card" style="width: 100%; padding: 16px 20px;">
    <div style="display: flex; align-items: center; justify-content: space-between; color: var(--text-muted);">
        <span>© {new Date().getFullYear()}</span>
        <a href="https://th-dd.top" style="color: inherit; text-decoration: none;">
            {t("footer.site")}
        </a>
        <a href="https://hyperos.mi.com/font" style="color: inherit; text-decoration: none;">
            {t("footer.font")}
        </a>
    </div>
</div>
