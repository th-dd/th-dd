---
import { getCollection } from 'astro:content';

const { post } = Astro.props;
---

<a href={`/nova/${post.slug}`} class="post-card">
  <h3>{post.data.title}</h3>
  <p class="desc">{post.data.description}</p>
  <span class="date">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
</a>

<style>
  .post-card {
    background: #fff;
    border: 2px solid #ff69b4;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    display: block;
    transition: all 0.2s;
  }
  
  .post-card:hover {
    box-shadow: 0 4px 15px rgba(255, 105, 180, 0.25);
    transform: translateY(-2px);
  }
  
  .post-card h3 {
    color: #d63384;
    margin: 0 0 0.5rem;
  }
  
  .post-card .desc {
    color: #666;
    margin: 0;
    font-size: 0.9rem;
  }
  
  .post-card .date {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: #999;
  }
</style>
