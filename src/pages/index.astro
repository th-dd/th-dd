---
import Profile from "../cards/profile.astro";
import Links from "../cards/links.astro";
import Footer from "../cards/footer.astro";
import About from "../cards/about.astro";
import Time from "../cards/time.astro";
import Skills from "../cards/skills.astro";
import Projects from "../cards/projects.astro";
import LinkDrawer from "../cards/LinkDrawer.astro";

import { initTastro, useTastro } from "@sipc.ink/tastro"

initTastro({
  defaultLang: "zh",
  languages: {
    en: () => import("../i18n/en.json"),
    zh: () => import("../i18n/zh.json"),
  }
})

const { t, lang} = useTastro(Astro.request)

---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{lang === "zh" ? "叹号大帝" : "thdd"}</title>
    <link rel="stylesheet" crossorigin="anonymous" href="https://cdn.jsdelivr.net/npm/misans@4.1.0/lib/Normal/MiSans-Medium.min.css"/>
  </head>
  <body>
    <div class="background-image"></div>
    <div class="background-overlay"></div>
    
    <!-- 主题切换按钮 -->
    <button id="theme-toggle" class="theme-toggle" aria-label="切换主题">
      <span class="icon-sun">☀️</span>
      <span class="icon-moon">🌙</span>
    </button>
    
    <main class="container">
        <div class="outer-grid">
            <div class="column-left">
                <Profile />
                <About />
                <Skills />
                <Links />
            </div>
            <div class="column-right">
                <Time />
                <Projects />
                <Footer />
            </div>
        </div>
    </main>
      <LinkDrawer />
</body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    html, body {
        font-family: 'MiSans', -apple-system, BlinkMacSystemFont, sans-serif;
        min-height: 100vh;
        transition: background-color 0.3s ease, color 0.3s ease;
    }
    
    /* 深色模式 (默认) */
    :root {
        --bg-primary: #1a1a1a;
        --bg-card: rgba(20, 20, 20, 0.65);
        --bg-card-inner: rgba(40, 40, 40, 0.5);
        --text-primary: #ffffff;
        --text-secondary: #cccccc;
        --text-muted: #888888;
        --border-color: rgba(255, 255, 255, 0.1);
        --overlay-color: rgba(0, 0, 0, 0.15);
        --btn-bg: rgba(255, 255, 255, 0.1);
        --btn-text: #ffffff;
    }
    
    /* 浅色模式 */
    :root.light {
        --bg-primary: #f0f0f0;
        --bg-card: rgba(255, 255, 255, 0.85);
        --bg-card-inner: rgba(230, 230, 230, 0.8);
        --text-primary: #1a1a1a;
        --text-secondary: #444444;
        --text-muted: #777777;
        --border-color: rgba(0, 0, 0, 0.1);
        --overlay-color: rgba(255, 255, 255, 0.3);
        --btn-bg: rgba(0, 0, 0, 0.08);
        --btn-text: #1a1a1a;
    }
    
    body {
        background: var(--bg-primary);
        color: var(--text-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    
    .background-image {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('https://api.yppp.net/api.php');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 0;
    }
    
    .background-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--overlay-color);
        z-index: 1;
    }
    
    .container {
        position: relative;
        z-index: 2;
        max-width: 730px;
        width: 100%;
    }
    
    /* 主题切换按钮 */
    .theme-toggle {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 100;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-color);
        font-size: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }
    
    .theme-toggle:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    }
    
    .theme-toggle .icon-sun {
        display: none;
    }
    
    .theme-toggle .icon-moon {
        display: block;
    }
    
    :root.light .theme-toggle .icon-sun {
        display: block;
    }
    
    :root.light .theme-toggle .icon-moon {
        display: none;
    }
    
    /* 毛玻璃卡片 - 强制颜色 */
    .glass-card {
        background: var(--bg-card) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        border-radius: 16px !important;
        border: 1px solid var(--border-color) !important;
        transition: all 0.3s ease;
    }
    
    /* 强制所有文字颜色 */
    .glass-card,
    .glass-card * {
        color: var(--text-primary) !important;
    }
    
    .glass-card h4,
    .glass-card h5 {
        color: var(--text-primary) !important;
    }
    
    .glass-card p {
        color: var(--text-secondary) !important;
    }
    
    .glass-card del {
        color: var(--text-muted) !important;
    }
    
    .glass-card a {
        color: var(--text-primary) !important;
    }
    
    .inner-card {
        background: var(--bg-card-inner) !important;
    }
    
    /* 技能标签 */
    .skill-badge {
        background: var(--btn-bg) !important;
        color: var(--text-primary) !important;
        border: 1px solid var(--border-color) !important;
    }
    
    /* 链接按钮 */
    .link-btn {
        background: var(--btn-bg) !important;
        color: var(--btn-text) !important;
        border: 1px solid var(--border-color) !important;
    }
    
    .link-btn svg {
        fill: var(--btn-text) !important;
    }
    
    /* 布局 - 不拉伸 */
    .outer-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 12px;
        align-items: start;
    }
    
    .column-left,
    .column-right {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    
    @media (max-width: 768px) {
        .outer-grid {
            grid-template-columns: 1fr;
        }
        
        .theme-toggle {
            top: 10px;
            right: 10px;
            width: 40px;
            height: 40px;
            font-size: 16px;
        }
    }
</style>

<script>
    // 主题切换逻辑
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    
    // 检查本地存储的主题
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'light') {
        html.classList.add('light');
    }
    
    // 切换主题
    themeToggle.addEventListener('click', () => {
        html.classList.toggle('light');
        const isLight = html.classList.contains('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
    });
</script>
