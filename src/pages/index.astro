---
import Profile from "../cards/profile.astro";
import Links from "../cards/links.astro";
import Footer from "../cards/footer.astro";
import About from "../cards/about.astro";
import Time from "../cards/time.astro";
import Skills from "../cards/skills.astro";
import Projects from "../cards/projects.astro";

import { initTastro, useTastro } from "@sipc.ink/tastro"

initTastro({
  defaultLang: "en",
  languages: {
    en: () => import("../i18n/en.json"),
    zh: () => import("../i18n/zh.json"),
  }
})

const { t, lang} = useTastro(Astro.request)

---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>th-dd.top</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'MiSans', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            background: #1a1a1a;
            color: #ffffff;
        }
        
        .background-image {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('https://api.yppp.net/api.php');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            z-index: 0;
        }
        
        .background-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.3);
            z-index: 1;
        }
        
        .container {
            max-width: 730px;
            margin: 0 auto;
            padding: 20px;
            min-height: 100vh;
            position: relative;
            z-index: 2;
        }
        
        /* 毛玻璃效果 */
        .glass-card {
            background: rgba(30, 30, 30, 0.75) !important;
            backdrop-filter: blur(10px) !important;
            -webkit-backdrop-filter: blur(10px) !important;
            border-radius: 16px !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
        }
        
        .outer-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 15px;
            min-height: calc(100vh - 40px);
        }
        
        .inner-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        @media (max-width: 768px) {
            .outer-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="background-image"></div>
    <div class="background-overlay"></div>
    <div class="container">
        <div class="outer-grid">
            <div class="inner-grid">
                <Profile />
                <About />
                <Skills />
                <Links />
            </div>
            <div class="inner-grid">
                <Time />
                <Projects />
                <Footer />
            </div>
        </div>
    </div>
</body>
</html>
