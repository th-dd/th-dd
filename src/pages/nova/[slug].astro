---
import { getCollection } from 'astro:content';
import Footer from "../../cards/footer.astro";

import { initTastro, useTastro } from "@sipc.ink/tastro"

initTastro({
  defaultLang: "zh",
  languages: {
    en: () => import("../../i18n/en.json"),
    zh: () => import("../../i18n/zh.json"),
  }
})

const { t, lang } = useTastro(Astro.request)

const { slug } = Astro.params;
const post = await getCollection('blog').then(posts => posts.find(p => p.slug === slug));

if (!post) {
  return Astro.redirect('/nova');
}

const { Content } = await post.render();
---

<html lang={lang === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} - Nova</title>
  </head>
  <body>
    <main>
      <article class="post">
        <header>
          <h1>{post.data.title}</h1>
          <p class="date">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
        </header>
        <div class="content">
          <Content />
        </div>
        <footer>
          <a href="/nova" class="back-link">← 回到Nova主页</a>
        </footer>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .post {
    background: #fff;
    border: 2px solid #ff69b4;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(255, 105, 180, 0.15);
  }
  
  .post header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #ffc0cb;
  }
  
  .post h1 {
    color: #d63384;
    margin: 0;
  }
  
  .post .date {
    color: #666;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }
  
  .post .content {
    line-height: 1.8;
    color: #333;
  }
  
  .post footer {
    margin-top: 2rem;
    text-align: center;
  }
  
  .back-link {
    color: #d63384;
    text-decoration: none;
  }
  
  .back-link:hover {
    text-decoration: underline;
  }
</style>
