---
import { getCollection } from 'astro:content';
import NovaCard from "../../cards/nova.astro";
import Footer from "../../cards/footer.astro";
import PostCard from "../../cards/post-card.astro";

import { initTastro, useTastro } from "@sipc.ink/tastro"

initTastro({
  defaultLang: "zh",
  languages: {
    en: () => import("../../i18n/en.json"),
    zh: () => import("../../i18n/zh.json"),
  }
})

const { t, lang } = useTastro(Astro.request)

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang={lang === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nova - {t("site.title") || "叹号大帝"}</title>
  </head>
  <body>
    <main>
      <NovaCard />
      
      <div class="posts-section">
        <h2>📝 {t("nova.posts") || "帖子"}</h2>
        <div class="posts-grid">
          {sortedPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .posts-section {
    margin-top: 2rem;
  }
  
  .posts-section h2 {
    color: #d63384;
    margin-bottom: 1rem;
  }
  
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
